# wolfe-run.yml — shared plumbing for every wolfe-pack bot.
#
# PURPOSE: Callers own the schedule, inputs, and prompt. This file owns
#   auth, checkout, stack setup, the Claude Code invocation, and artifact
#   upload.  It is generated by `npx wolfe-pack init` — but YOU OWN IT.
#   Edit freely; re-running init will not overwrite changes you make here.
#
# SERIALIZATION: all bots share a single concurrency group so their writes
#   never race. Crons are staggered (see caller workflows) for politeness,
#   not correctness — this lock is the correctness backstop.

name: "wolfe-pack: shared runner"

on:
  workflow_call:
    inputs:
      bot-name:
        description: "Which bot to run (e.g. wolfe-bugs, wolfe-fixer)"
        type: string
        required: true
      prompt:
        description: "Full prompt block passed to Claude Code"
        type: string
        required: true
      ref:
        description: "Git ref to check out"
        type: string
        default: "<<DEFAULT_BRANCH>>"
      since:
        description: "Time-window passed to the bot (e.g. 8d, 2w). Empty = bot default."
        type: string
        default: ""
      area:
        description: "Area name from wolfe/areas to scope this run. Empty = bot selects."
        type: string
        default: ""
      dry-run:
        description: "When true, write reports to .wolfe/reports/ instead of filing issues/PRs"
        type: boolean
        default: false
      timeout-minutes:
        description: "Hard wall-clock cap for the run job"
        type: number
        default: 90
      session-retention-days:
        description: "How many days to retain the uploaded session-log artifact"
        type: string
        default: "7"
    secrets:
      # Provide exactly one of these two model credentials.
      CLAUDE_CODE_OAUTH_TOKEN:
        description: "Claude Code OAuth token (claude.ai subscription)"
        required: false
      ANTHROPIC_API_KEY:
        description: "Anthropic API key (pay-per-token)"
        required: false
      # Optional: your own GitHub App for signed commits + CI-triggering PRs.
      # Without it, bots can still open issues and unverified draft PRs using
      # the built-in GITHUB_TOKEN — but those PRs will NOT trigger CI and
      # cannot satisfy a 'require CI green' branch-protection rule.
      WOLFE_APP_ID:
        description: "GitHub App ID (from your App's settings page)"
        required: false
      WOLFE_APP_PRIVATE_KEY:
        description: "GitHub App private key (PEM, base64-encoded or raw)"
        required: false

jobs:
  run:
    name: "run ${{ inputs.bot-name }}"
    runs-on: ubuntu-latest
    timeout-minutes: ${{ inputs.timeout-minutes }}
    # Serialize ALL bot runs. Crons are staggered across days/hours for
    # politeness, but this concurrency group is the correctness backstop that
    # prevents two bots from writing to the same files simultaneously.
    concurrency:
      group: wolfe-pack-runner
      cancel-in-progress: false
    permissions:
      contents: write
      pull-requests: write
      issues: write
      actions: read
      id-token: write

    steps:
      # ── (a) Validate inputs ─────────────────────────────────────────────────
      - name: Validate inputs
        env:
          SINCE: ${{ inputs.since }}
          AREA: ${{ inputs.area }}
        shell: bash
        run: |
          if [[ -n "$SINCE" ]] && ! [[ "$SINCE" =~ ^[0-9]+[dhw]$ ]]; then
            echo "::error::Input 'since' must be empty or match ^[0-9]+[dhw]$ (e.g. 8d, 2w, 1h). Got: $SINCE"
            exit 1
          fi
          if [[ -n "$AREA" ]] && ! [[ "$AREA" =~ ^[A-Za-z0-9._/-]{1,64}$ ]]; then
            echo "::error::Input 'area' must be empty or match ^[A-Za-z0-9._/-]{1,64}$. Got: $AREA"
            exit 1
          fi

      # ── (b) Require a model credential ──────────────────────────────────────
      - name: Require model credential
        env:
          HAS_OAUTH: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN != '' }}
          HAS_KEY: ${{ secrets.ANTHROPIC_API_KEY != '' }}
        shell: bash
        run: |
          if [[ "$HAS_OAUTH" != "true" && "$HAS_KEY" != "true" ]]; then
            echo "::error::No model credential found. Provide at least one of:"
            echo "::error::  gh secret set CLAUDE_CODE_OAUTH_TOKEN --body '<token>'"
            echo "::error::  gh secret set ANTHROPIC_API_KEY --body '<key>'"
            exit 1
          fi

      # ── (c) Checkout ─────────────────────────────────────────────────────────
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{ inputs.ref }}
          # Full history: bots need it to determine which areas are least
          # recently hunted (they read the git log and the run-log issue).
          fetch-depth: 0

      # ── (d) Stack setup ───────────────────────────────────────────────────────
      # ── stack setup (generated from your detected stack; edit freely) ──
      <<SETUP_STEPS>>
      # ── end stack setup ──

      # ── (e) Install dependencies ──────────────────────────────────────────────
      # continue-on-error: a degraded environment (install fails) downgrades
      # findings to [unverified] issues — it never kills the run entirely.
      - name: Install dependencies
        id: install
        continue-on-error: true
        run: <<INSTALL_COMMAND>>

      # ── (f) Record environment status ────────────────────────────────────────
      - name: Record environment status
        shell: bash
        env:
          INSTALL_OUTCOME: ${{ steps.install.outcome }}
        run: |
          mkdir -p .wolfe/runs
          INSTALL_OK=false
          if [[ "$INSTALL_OUTCOME" == "success" ]]; then
            INSTALL_OK=true
          fi
          cat > .wolfe/runs/env-status.json <<EOF
          {
            "backend": "actions",
            "install_ok": $INSTALL_OK
          }
          EOF

      # ── (g) Mint bot identity token ───────────────────────────────────────────
      # Two-step pattern: secrets context is available in step `env:` but NOT
      # in step `if:` expressions. We check nonemptiness via env vars in the
      # first step and gate the token-creation step on its output.
      - name: Check App credentials
        id: app-check
        env:
          APP_ID: ${{ secrets.WOLFE_APP_ID }}
          APP_KEY: ${{ secrets.WOLFE_APP_PRIVATE_KEY }}
        shell: bash
        run: |
          if [[ -n "$APP_ID" && -n "$APP_KEY" ]]; then
            echo "has_app=true" >> "$GITHUB_OUTPUT"
          else
            echo "has_app=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Mint bot identity token
        id: bot-token
        if: steps.app-check.outputs.has_app == 'true'
        uses: actions/create-github-app-token@v2
        with:
          app-id: ${{ secrets.WOLFE_APP_ID }}
          private-key: ${{ secrets.WOLFE_APP_PRIVATE_KEY }}

      # ── (h) Run the bot ───────────────────────────────────────────────────────
      - name: Run ${{ inputs.bot-name }}
        uses: anthropics/claude-code-action@v1
        with:
          # With your GitHub App → bot PRs trigger CI + commits are signed and
          # attributed to the App. Without it (issues-only autonomy) the built-in
          # GITHUB_TOKEN is sufficient and no App setup is needed.
          github_token: ${{ steps.bot-token.outputs.token || github.token }}
          claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
          prompt: ${{ inputs.prompt }}
          use_commit_signing: true
          claude_args: >-
            --append-system-prompt
            "You are running unattended in CI.
            Never run git commit or git push via the shell: this runner has no
            signing key, so raw git commits would be unsigned (rejected wherever
            signed commits are required) and mis-attributed.
            Create branches and commits only through the built-in
            signed-commit mechanism.
            You must never merge, approve, or enable auto-merge on any pull
            request, and never modify files under .github/workflows."

      # ── (i) Locate session log ────────────────────────────────────────────────
      - name: Locate session log
        id: session-log
        if: always()
        shell: bash
        run: |
          LOG_PATH="${RUNNER_TEMP}/claude-execution-output.json"
          if [[ -f "$LOG_PATH" ]]; then
            echo "found=true" >> "$GITHUB_OUTPUT"
            echo "path=$LOG_PATH" >> "$GITHUB_OUTPUT"
          else
            echo "found=false" >> "$GITHUB_OUTPUT"
            echo "::warning::Session log not found at $LOG_PATH — token/cost data will be unavailable in the run summary."
          fi

      # ── (j) Upload session log artifact ──────────────────────────────────────
      - name: Upload session log
        if: always() && steps.session-log.outputs.found == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: wolfe-session-${{ inputs.bot-name }}-${{ github.run_id }}
          path: ${{ steps.session-log.outputs.path }}
          retention-days: ${{ inputs.session-retention-days }}

      # ── (k) Upload dry-run report ─────────────────────────────────────────────
      - name: Upload dry-run report
        if: inputs.dry-run
        uses: actions/upload-artifact@v4
        with:
          name: wolfe-dryrun-${{ inputs.bot-name }}-${{ github.run_id }}
          path: .wolfe/reports/*-dryrun.md
          retention-days: 30
          if-no-files-found: warn
